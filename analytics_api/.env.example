APP_NAME=Odoo Analytics API
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1
SECRET_KEY=change-this-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080
JWT_ISSUER=odoo-analytics-api
JWT_AUDIENCE=analytics-clients
CORS_ORIGINS=["https://lookerstudio.google.com","https://app.powerbi.com","https://tableau.yourdomain.com"]
DB_HOST=postgres
DB_PORT=5432
DB_NAME=odoo
DB_USER=analytics_app
DB_PASSWORD=change-me
DB_SCHEMA=analytics
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false
REDIS_URL=redis://redis:6379/0
REDIS_DEFAULT_TTL=300
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_AUTH=20/minute
ADMIN_EMAIL=admin
ADMIN_PASSWORD=admin
ADMIN_FULL_NAME=Platform Admin
LOG_LEVEL=INFO
TRUSTED_HOSTS=["api.example.com","localhost","127.0.0.1"]
SECURE_SSL_REDIRECT=false
ENABLE_METRICS=true
SWAGGER_ENABLED=true
