<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_public_holiday_list" model="ir.ui.view">
        <field name="name">public.holiday.list</field>
        <field name="model">public.holiday</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="date"/>
            </list>
        </field>
    </record>

    <record id="action_public_holiday" model="ir.actions.act_window">
        <field name="name">Bayram kunlari</field>
        <field name="res_model">public.holiday</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu: Configuration ostiga bayramlarni qo'shamiz -->
    <menuitem id="menu_public_holiday"
              name="Bayramlar"
              parent="openeducat_core.menu_op_school_config"
              action="action_public_holiday"
              sequence="50"/>
</odoo>
