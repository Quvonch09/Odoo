<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crm_lead_view_form_moizvonki" model="ir.ui.view">
        <field name="name">crm.lead.form.moizvonki</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="sfera_admission_custom.crm_lead_view_form_sfera_restored"/>
        <field name="arch" type="xml">
            <!-- 
                Tugmani "Guruhga qo'shish" tugmasining yoniga joylashtiramiz. 
                Bu usul headerda aniq ko'rinishini ta'minlaydi.
            -->
            <xpath expr="//button[@name='%(sfera_admission_custom.action_crm_lead_to_student_wizard)d']" position="before">
                <button name="%(sfera_moizvonki.moizvonki_call_action_start)d" type="action" 
                        string="QO'NG'IROQ (Moi Zvonki)" class="btn-primary" 
                        invisible="not student_phone and not parent_phone"
                        confirm="Haqiqatan ham telefon qilmoqchimisiz?"/>
            </xpath>
            
            <!-- Telefon raqam widgeti yoniga faqat kichik belgi qo'shamiz -->
            <xpath expr="//field[@name='student_phone']" position="after">
                <button name="%(sfera_moizvonki.moizvonki_call_action_start)d" type="action" 
                        string="" class="btn-sm btn-link text-primary p-0 ms-1" icon="fa-phone"
                        invisible="not student_phone"/>
            </xpath>
        </field>
    </record>

    <!-- Server Action -->
    <record id="moizvonki_call_action_start" model="ir.actions.server">
        <field name="name">Moi Zvonki: Start Call</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="state">code</field>
        <field name="code">
phone = record.student_phone or record.parent_phone
if phone:
    action = env['moizvonki.call'].action_make_call(phone)
    if action:
        record.message_post(body=f"Moi Zvonki orqali {phone} raqamiga qo'ng'iroq buyrug'i yuborildi.")
        </field>
    </record>
</odoo>
