<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_moizvonki" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.moizvonki</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='contacts_setting_container']" position="after">
                <block title="Moi Zvonki Integration" name="moizvonki_settings">
                    <setting id="moizvonki_api_settings" string="API Credentials" help="Configure your Moi Zvonki API Key and Address">
                        <div class="content-group">
                            <div class="mt16">
                                <label for="moizvonki_api_address" class="o_light_label"/>
                                <field name="moizvonki_api_address" placeholder="e.g. sferaacademy.moizvonki.ru"/>
                            </div>
                            <div class="mt16">
                                <label for="moizvonki_user_name" class="o_light_label"/>
                                <field name="moizvonki_user_name" placeholder="e.g. admin@sfera.uz"/>
                            </div>
                            <div class="mt16">
                                <label for="moizvonki_api_key" class="o_light_label"/>
                                <field name="moizvonki_api_key" password="True"/>
                            </div>
                            <div class="mt16">
                                <button name="action_moizvonki_test_connection" type="object" string="Test Connection" class="btn-primary" icon="oi-arrow-right"/>
                            </div>
                            <div class="mt16">
                                <strong>Webhook URL:</strong> <br/>
                                <code class="text-primary">https://your-odoo-domain.com/moizvonki/webhook</code>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
