<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="moizvonki_call_view_tree" model="ir.ui.view">
        <field name="name">moizvonki.call.list</field>
        <field name="model">moizvonki.call</field>
        <field name="arch" type="xml">
            <list decoration-danger="status == 'missed'" decoration-success="status == 'answered'">
                <field name="start_time"/>
                <field name="phone"/>
                <field name="direction"/>
                <field name="status"/>
                <field name="duration" widget="float_time"/>
                <field name="partner_id"/>
                <field name="lead_id"/>
                <field name="recording_url" widget="url" text="Record"/>
            </list>
        </field>
    </record>

    <record id="moizvonki_call_view_form" model="ir.ui.view">
        <field name="name">moizvonki.call.form</field>
        <field name="model">moizvonki.call</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="phone"/>
                            <field name="direction"/>
                            <field name="status"/>
                            <field name="start_time"/>
                        </group>
                        <group>
                            <field name="duration"/>
                            <field name="partner_id"/>
                            <field name="lead_id"/>
                            <field name="recording_url" widget="url"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="moizvonki_call_action" model="ir.actions.act_window">
        <field name="name">Calls History</field>
        <field name="res_model">moizvonki.call</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_moizvonki_root" name="Moi Zvonki" parent="crm.crm_menu_root" sequence="100"/>
    <menuitem id="menu_moizvonki_call" name="Calls" parent="menu_moizvonki_root" action="moizvonki_call_action"/>
</odoo>
