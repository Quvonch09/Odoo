<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_sfera_attendance_dashboard" model="ir.actions.client">
        <field name="name">Davomat Paneli</field>
        <field name="tag">sfera_attendance_dashboard</field>
        <field name="target">main</field>
    </record>

    <record id="view_op_batch_form_inherit_attendance" model="ir.ui.view">
        <field name="name">op.batch.form.inherit.attendance</field>
        <field name="model">op.batch</field>
        <field name="inherit_id" ref="openeducat_core.view_op_batch_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_sfera_attendance" 
                        string="Take Attendance" 
                        type="object" 
                        class="oe_highlight"
                        icon="fa-calendar-check-o"/>
            </xpath>
        </field>
    </record>

    <record id="view_op_attendance_sheet_form_inherit_sfera" model="ir.ui.view">
        <field name="name">op.attendance.sheet.form.inherit.sfera</field>
        <field name="model">op.attendance.sheet</field>
        <field name="inherit_id" ref="openeducat_attendance.view_op_attendance_sheet_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='attendance_line']/list/field[@name='present']" position="before">
                <field name="sfera_status" string="Status"/>
            </xpath>
        </field>
    </record>
</odoo>
