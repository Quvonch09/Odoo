<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- 
        Sfera Calendar menyusini endi to'g'ridan to'g'ri OpenEduCat standart sessiyalariga (op.session) yo'naltiramiz.
        Bu "tushunarsiz" texnik ko'rinishlarni yo'qotadi va tizim bilan to'liq integratsiyani ta'minlaydi.
    -->

    <!-- Sfera uchun maxsus kalendar ko'rinishi (op.session uchun) -->
    <record id="view_op_session_calendar_sfera" model="ir.ui.view">
        <field name="name">op.session.calendar.sfera</field>
        <field name="model">op.session</field>
        <field name="priority" eval="100"/>
        <field name="arch" type="xml">
            <calendar string="Sfera Darslari" date_start="start_datetime" date_stop="end_datetime" color="faculty_id" mode="month" quick_create="False">
                <field name="batch_id"/>
                <field name="subject_id"/>
                <field name="faculty_id"/>
            </calendar>
        </field>
    </record>

    <!-- Yangi Action: op.session modelidan foydalanadi -->
    <record id="action_sfera_calendar_integrated" model="ir.actions.act_window">
        <field name="name">Sfera Calendar</field>
        <field name="res_model">op.session</field>
        <field name="view_mode">calendar,list,form,pivot</field>
        <field name="view_id" ref="view_op_session_calendar_sfera"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Hali hech qanday dars sessiyalari yaratilmagan.
            </p>
            <p>Guruh (Batch) ichida "Jadvalni shakllantirish" tugmasini bosib sessiyalar yaratishingiz mumkin.</p>
        </field>
    </record>

    <!-- Sfera Calendar menyusi endi standart sessiyalarni ochadi -->
    <menuitem id="menu_sfera_calendar" 
              name="Sfera Calendar" 
              parent="openeducat_core.menu_op_school_root" 
              action="action_sfera_calendar_integrated" 
              sequence="45"/>
</odoo>
