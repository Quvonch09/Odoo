<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_op_course_form_lesson_inherit" model="ir.ui.view">
        <field name="name">op.course.form.lesson.inherit</field>
        <field name="model">op.course</field>
        <field name="inherit_id" ref="openeducat_core.view_op_course_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='subject']" position="after">
                <page string="Lessons" name="lessons">
                    <field name="lesson_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="description"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
