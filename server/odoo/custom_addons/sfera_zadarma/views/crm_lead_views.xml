<odoo>
    <record id="crm_lead_view_form_inherit_zadarma" model="ir.ui.view">
        <field name="name">crm.lead.view.form.inherit.sfera.zadarma</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="sfera_admission_custom.crm_lead_view_form_sfera_restored"/>
        <field name="priority" eval="2"/>
        <field name="arch" type="xml">
            <!-- Asosiy telefon yoniga Call tugmasini joylashtirish -->
            <xpath expr="//div[@name='student_phone_row']" position="inside">
                <button name="action_zadarma_call" 
                        string="Qo'ng'iroq" 
                        type="object" 
                        icon="fa-phone" 
                        class="btn btn-outline-success btn-sm ms-3"
                        title="Zadarma orqali qo'ng'iroq"
                        invisible="not student_phone"/>
            </xpath>
            
            <!-- Vasiy telefoni yoniga Call tugmasini joylashtirish -->
            <xpath expr="//div[@name='parent_phone_row']" position="inside">
                <button name="action_zadarma_call_parent" 
                        string="Qo'ng'iroq" 
                        type="object" 
                        icon="fa-phone" 
                        class="btn btn-outline-success btn-sm ms-3"
                        title="Zadarma orqali qo'ng'iroq"
                        invisible="not parent_phone"/>
            </xpath>
        </field>
    </record>
</odoo>
