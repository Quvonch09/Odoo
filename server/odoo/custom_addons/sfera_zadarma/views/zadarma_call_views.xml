<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="zadarma_call_view_list" model="ir.ui.view">
        <field name="name">zadarma.call.list</field>
        <field name="model">zadarma.call</field>
        <field name="arch" type="xml">
            <list decoration-danger="status in ('failed', 'busy', 'cancel', 'no_answer')" decoration-success="status == 'answered'">
                <field name="call_start"/>
                <field name="direction"/>
                <field name="phone"/>
                <field name="internal_extension"/>
                <field name="status"/>
                <field name="duration"/>
                <field name="lead_id"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="recording_url" widget="url" text="Recording"/>
            </list>
        </field>
    </record>

    <record id="zadarma_call_view_form" model="ir.ui.view">
        <field name="name">zadarma.call.form</field>
        <field name="model">zadarma.call</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="pbx_call_id"/>
                            <field name="event"/>
                            <field name="direction"/>
                            <field name="status"/>
                            <field name="call_start"/>
                        </group>
                        <group>
                            <field name="phone"/>
                            <field name="caller_id"/>
                            <field name="called_did"/>
                            <field name="destination"/>
                            <field name="internal_extension"/>
                            <field name="duration"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="lead_id"/>
                            <field name="partner_id"/>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="is_recorded"/>
                            <field name="call_id_with_rec"/>
                            <field name="recording_url" widget="url"/>
                        </group>
                    </group>
                    <group>
                        <field name="payload" widget="text" readonly="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="zadarma_call_action" model="ir.actions.act_window">
        <field name="name">Zadarma Calls</field>
        <field name="res_model">zadarma.call</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_zadarma_root" name="Zadarma" parent="crm.crm_menu_root" sequence="110"/>
    <menuitem id="menu_zadarma_calls" name="Calls" parent="menu_zadarma_root" action="zadarma_call_action" sequence="10"/>
</odoo>
