<odoo>
    <record id="view_student_excel_import_wizard_form" model="ir.ui.view">
        <field name="name">student.excel.import.wizard.form</field>
        <field name="model">student.excel.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Student Excel Import">
                <group>
                    <field name="file" filename="file_name"/>
                    <field name="file_name" invisible="1"/>
                    <div class="o_form_label">
                        Excel ustunlari quyidagicha bo'lishi kerak: Ism-familiya, Yosh, Telefon raqam, Ota-onasining ismi, Ota-onasining telefon raqami, Guruh
                    </div>
                </group>
                <footer>
                    <button name="action_import_file" string="Import qilish" type="object" class="btn-primary"/>
                    <button string="Bekor qilish" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_student_excel_import_wizard" model="ir.actions.act_window">
        <field name="name">Student Excel Import</field>
        <field name="res_model">student.excel.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="action_open_student_excel_import_wizard_server" model="ir.actions.server">
        <field name="name">Student Excel Import</field>
        <field name="model_id" ref="openeducat_core.model_op_student"/>
        <field name="binding_model_id" ref="openeducat_core.model_op_student"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">action = env.ref('sfera_admission_custom.action_student_excel_import_wizard').read()[0]</field>
    </record>

    <record id="action_export_student_excel_server" model="ir.actions.server">
        <field name="name">Student Excel Export</field>
        <field name="model_id" ref="openeducat_core.model_op_student"/>
        <field name="binding_model_id" ref="openeducat_core.model_op_student"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">action = records.action_export_student_excel()</field>
    </record>

    <record id="action_download_student_excel_template_server" model="ir.actions.server">
        <field name="name">Student Excel Shablon</field>
        <field name="model_id" ref="openeducat_core.model_op_student"/>
        <field name="binding_model_id" ref="openeducat_core.model_op_student"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">action = env['op.student'].action_download_student_excel_template()</field>
    </record>
</odoo>
